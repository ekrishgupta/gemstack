#!/usr/bin/env bash
# gemstack-review-read — read review log and config for dashboard
# Usage: gemstack-review-read
set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
eval $("$SCRIPT_DIR/gemstack-slug" 2>/dev/null)
GEMSTACK_HOME="${GEMSTACK_HOME:-$HOME/.gemstack}"
cat "$GEMSTACK_HOME/projects/$SLUG/$BRANCH-reviews.jsonl" 2>/dev/null || echo "NO_REVIEWS"
echo "---CONFIG---"
"$SCRIPT_DIR/gemstack-config" get skip_eng_review 2>/dev/null || echo "false"
echo "---HEAD---"
git rev-parse --short HEAD 2>/dev/null || echo "unknown"
